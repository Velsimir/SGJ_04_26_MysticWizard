  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0417\u043B\u043E\u0439 \u0432\u043E\u043B\u0448\u0435\u0431\u043D\u0438\u043A
    \u041C\u044B\u0448\u043E\u0432\u0443\u0440 \u043F\u043E\u0440\u0430\u0431\u043E\u0449\u0430\u0435\u0442
    \u0441\u043A\u0430\u0437\u043E\u0447\u043D\u044B\u0435 \u043D\u0430\u0440\u043E\u0434\u044B,
    \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u0438 \u043D\u0430\u0448\u043B\u0438
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0443\u0442\u0435\u0440\u044F\u043D\u043D\u044B\u0439
    \u0442\u043E\u043C \u043C\u043E\u0433\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0433\u0438\u0438 \u201C\u041C\u0435\u0442\u0430\u043C\u043E\u0440\u0444\u043E\u0437\u044B
    \u0434\u043B\u044F \u0447\u0430\u0439\u043D\u0438\u043A\u043E\u0432\u201D. \r\n\r\n\u0414\u043B\u044F
    \u043F\u043E\u0438\u0441\u043A\u043E\u0432 \u043A\u043D\u0438\u0433\u0438 \u043E\u043D
    \u0441\u043E\u0431\u0438\u0440\u0430\u0435\u0442 \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438
    \u043F\u043E \u0440\u0430\u0437\u043D\u044B\u043C \u0440\u0443\u0438\u043D\u0430\u043C
    \u0434\u0440\u0435\u0432\u043D\u0438\u0445. \u0412 \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0442\u0430\u043A\u0438\u0445 \u0440\u0430\u0441\u043A\u043E\u043F\u043E\u043A
    \u0431\u0435\u0434\u043D\u0430\u044F \u0444\u0435\u044F \u042D\u043B\u0435\u043D\u0434\u0438\u0440\u0430
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442 \u0432\u043E\u043B\u0448\u0435\u0431\u043D\u0443\u044E
    \u043A\u043D\u0438\u0433\u0443, \u0438 \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0449\u0438\u0442\u0438\u0442\u044C
    \u0432\u0435\u0441\u044C \u043C\u0438\u0440, \u0440\u0438\u0441\u043A\u0443\u044F
    \u0432\u0441\u0435\u043C, \u0441\u0431\u0435\u0433\u0430\u0435\u0442 \u0438\u0437
    \u043B\u0430\u0433\u0435\u0440\u044F.\r\n\r\n\u0412 \u043F\u043E\u043F\u044B\u0442\u043A\u0430\u0445
    \u0441\u043A\u0440\u044B\u0442\u044C\u0441\u044F \u043E\u0442 \u0433\u043E\u043D\u0447\u0438\u0445
    \u043C\u044B\u0448\u0435\u0439 \u043E\u043D\u0430 \u0432\u0438\u0434\u0438\u0442
    \u0431\u0430\u0448\u043D\u044E \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u0432\u043E\u043B\u0448\u0435\u0431\u043D\u0438\u043A\u0430."
